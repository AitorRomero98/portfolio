---
import BaseLayout from "../components/layout/BaseLayout.astro";
import Layout from "../components/layout/Layout.astro";
import Feed from "../components/feed/Feed.astro";

import { loadTextPosts, loadMediaPosts, loadProjects } from "../lib/content-loader";
import { buildFeed } from "../lib/feed-builder";

// Load content directly
const textposts = await loadTextPosts();
const mediaposts = await loadMediaPosts();

// Build the feed (mix posts + project entries)
const feedItems = buildFeed(textposts, mediaposts);
---

<BaseLayout title="Home" description="Latest updates from my personal space">
  <Layout>
    <Feed items={feedItems} />
  </Layout>
</BaseLayout>
